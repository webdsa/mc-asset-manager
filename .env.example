# PostgreSQL local (docker compose: user studio, db studio_assets)
DATABASE_URL="postgresql://studio:studio@localhost:5432/studio_assets"

# Imagens (públicas) e notas fiscais (privadas, pasta `invoices/`) → Vercel Blob.
# Use um Blob store **Private** no dashboard para NFs não ficarem acessíveis pela URL do storage.
# Em produção o token costuma ser injetado automaticamente. Local: `vercel env pull`.
BLOB_READ_WRITE_TOKEN=

# E-mail para solicitação de apólice (Resend): destino dos dados do formulário.
RESEND_API_KEY=
INSURANCE_QUOTE_EMAIL=
# Cópia (CC) e Reply-To: um ou vários endereços separados por vírgula. Quem recebe em Para
# responde para estes endereços (cabeçalho Reply-To + aviso no corpo do e-mail).
# INSURANCE_QUOTE_EMAIL_CC=
# Remetente verificado no Resend (ex.: "Studio <seguro@seudominio.com>"). Em testes pode omitir (usa onboarding@resend.dev).
# RESEND_FROM_EMAIL=

# Firebase Authentication (opcional). Com todas as variáveis abaixo, o app exige login e cookies de sessão nas rotas.
# Console: Firebase → Configurações do projeto → Seus apps → Web → copie o objeto firebaseConfig.
# Authentication → Sign-in method → ative "Google" e "E-mail/senha".
# Conta de serviço (Admin SDK): Configurações → Contas de serviço → Gerar nova chave privada → JSON inteiro em uma linha.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# O campo "project_id" deste JSON tem de ser o mesmo que NEXT_PUBLIC_FIREBASE_PROJECT_ID.