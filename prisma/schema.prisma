generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ItemCondition {
  NEW
  GOOD
  NEEDS_REPAIR
  RETIRED
}

enum InsuranceStatus {
  INSURED
  PENDING
  EXPIRED
  NOT_INSURED
}

/// Leitura: ver itens da categoria. Edição: criar/alterar/excluir itens nessa categoria.
enum CategoryAccessLevel {
  READ
  EDIT
}

enum UserRole {
  USER
  ADMIN
  /// Identificado por ASSET_MANAGER_OWNER_FIREBASE_UID no .env; não atribuível pela UI.
  OWNER
}

enum UserAccessStatus {
  PENDING
  APPROVED
  REVOKED
}

enum ItemAuditAction {
  CREATE
  UPDATE
  SOFT_DELETE
  PERMANENT_DELETE
  IMAGE_REMOVE
}

model Category {
  id           String               @id @default(cuid())
  name         String               @unique
  color        String
  /// Itens desta categoria aparecem no catálogo público na raiz (`/`).
  isPublic     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  items        Item[]
  userAccesses UserCategoryAccess[]
}

model User {
  id               String             @id @default(cuid())
  firebaseUid      String             @unique
  email            String?
  displayName      String?
  role             UserRole           @default(USER)
  accessStatus     UserAccessStatus   @default(PENDING)
  approvedAt       DateTime?
  approvedByUserId String?
  approvedBy       User?              @relation("UserApproval", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvalsGranted User[]             @relation("UserApproval")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  categoryAccesses UserCategoryAccess[]
}

model UserCategoryAccess {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  level      CategoryAccessLevel

  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
}

model Item {
  id               String          @id @default(cuid())
  name             String
  description      String?
  categoryId       String
  category         Category        @relation(fields: [categoryId], references: [id])
  brand            String?
  model            String?
  serialNumber     String?         @unique
  /// Código de patrimônio (contabilidade / inventário físico).
  patrimonyCode    String?         @unique
  /// Conteúdo ou identificador associado ao código QR do ativo.
  qrCode           String?
  /// Quantidade de unidades representadas por este registro (≥ 1).
  quantity         Int             @default(1)
  location         String?
  purchaseYear     Int
  purchaseDate     DateTime?
  purchaseValue    Decimal?        @db.Decimal(12, 2)
  supplier         String?
  condition        ItemCondition   @default(GOOD)
  insuranceStatus  InsuranceStatus @default(NOT_INSURED)
  insuranceCompany String?
  insurancePolicy  String?
  insuranceExpires DateTime?
  warrantyExpires  DateTime?
  notes            String?
  invoiceFileName  String?
  /// Caminho local `/uploads/invoices/...` ou URL do Vercel Blob (privada ou pública). Leitura via `/api/items/[id]/invoice`.
  invoiceFileUrl   String?
  images           ItemImage[]
  /// Preenchido ao “excluir” no admin: item some da lista e do catálogo público; o registro permanece no banco.
  hiddenAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([categoryId])
  @@index([hiddenAt])
  @@index([insuranceStatus])
  @@index([condition])
  @@index([purchaseYear])
}

/// Histórico de alterações em ativos (data UTC no banco; exibir em America/Sao_Paulo na UI).
model ItemAuditLog {
  id                 String          @id @default(cuid())
  itemId             String
  itemNameSnapshot   String?
  actorUserId        String?
  actorEmail         String?
  actorDisplayName   String?
  action             ItemAuditAction
  metadata           Json?
  createdAt          DateTime        @default(now())

  @@index([itemId])
  @@index([createdAt])
  @@index([actorUserId])
}

model ItemImage {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url       String
  fileName  String
  alt       String?
  createdAt DateTime @default(now())

  @@index([itemId])
}
